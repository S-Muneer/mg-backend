# Use NEON_DATABASE_URL for Neon Postgres in production/staging.
NEON_DATABASE_URL="postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require"
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
PORT=5000
JWT_SECRET="replace-with-strong-secret"
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
ADMIN_EMAIL="admin@mgfashions.com"
ADMIN_PASSWORD="Admin@123"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER="mg-fashions"
CLOUDINARY_DEFAULT_IMAGE_URL="https://res.cloudinary.com/demo/image/upload/c_fill,g_auto,h_1100,w_900/sample.jpg"
